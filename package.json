{
	"name": "d1-gridword",
	"description": "Gridword daily leaderboard backed by Cloudflare Workers + D1.",
	"devDependencies": {
		"typescript": "5.9.3",
		"wrangler": "4.56.0"
	},
	"private": true,
	"scripts": {
		"cf-typegen": "wrangler types",
		"check": "tsc && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "npm run seedLocalD1 && wrangler dev",
		"predeploy": "wrangler d1 migrations apply DB --remote",
		"seedLocalD1": "wrangler d1 migrations apply DB --local"
	}
}
